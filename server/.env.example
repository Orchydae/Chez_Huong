# Application
NODE_ENV=production
PORT=3000

# Look for this email: noreply@api.data.gov
USDA_API_KEY=
GOOGLE_CLOUD_TRANSLATION_API_KEY=

# Frontend origin used for CORS — your deployed frontend URL, or leave empty (http://localhost:5173) in dev
CLIENT_URL=

# Generated on Supabase Dashboard → Project Settings → JWT Keys
JWT_SECRET=

# Supabase Dashboard → Project Settings → Database → Connection string → "Transaction pooler" (IPv4-friendly, used at runtime)
DATABASE_URL=

# Supabase Dashboard → Project Settings → Database → Connection string → "Direct connection" (used for Prisma migrations from your machine)
DIRECT_URL=

# Supabase Dashboard → Project Settings → API → "Project URL"
SUPABASE_URL=

# Supabase Dashboard → Project Settings → API Keys → "service_role" (secret key — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Dashboard → Storage → bucket name
SUPABASE_BUCKET=
